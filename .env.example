# Copie este arquivo para .env e preencha com suas chaves de API
# Nunca compartilhe o arquivo .env

# Groq — transcrição de áudio via Whisper
# Obtenha em: https://console.groq.com
GROQ_API_KEY=sua_chave_aqui

# Anthropic Claude — sumarização (backend "claude")
# Obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=sua_chave_aqui

# Google Gemini — sumarização (backend "gemini", padrão)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_aqui
